# =====================================================
# Masterson Transaction Tracker — Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit .env to git
# =====================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key (not anon)
SUPABASE_BUCKET=receipts   # Storage bucket name for receipt photos

# --- Plaid ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production   # sandbox | development | production
PLAID_ACCESS_TOKEN=    # filled in after running scripts/plaid_link.py

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18005551234   # your Twilio number (E.164 format)

# --- App ---
ADMIN_PHONE=+14155551234           # YOUR phone number (Brandon)
ADMIN_EMAIL=brandon@example.com
REMINDER_INTERVAL_HOURS=24         # how often to re-remind if no reply
MAX_REMINDERS=3                    # stop reminding after this many attempts
DAYS_TO_LOOK_BACK=7                # how many days back to check for uncoded transactions
SECRET_KEY=some-random-string-for-jwt   # generate with: python -c "import secrets; print(secrets.token_hex(32))"
